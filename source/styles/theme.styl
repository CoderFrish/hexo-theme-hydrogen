/* 与布局有关的 */
:root {
  --z-index-sticky 100

  --text-xl 1.25rem
  --text-sm .875rem
  --text-2xl 1.5rem
  --text-lg 1.125rem
  --text-3xl 1.875rem
  --text-base 1rem

  --spacing-sm .5rem
  --spacing-xs .25rem
  --spacing-md 1rem
  --spacing-lg 1.5rem
  --spacing-xl 2rem
  --spacing-2xl 3rem

  --radius-md 8px
  --redius-full 100%
}

/* 明色主题色调 */
[data-theme="light"] {
  --primary-normal-color #2563eb
  --primary-light-color #dbeafe

  --text-primary-color #1e293b
  --text-secondary-color #475569
  --text-muted-color #94a3b8
  --text-inverse-color #ffffff

  --bg-primary-color #ffffff
  --bg-secondary-color #f8fafc
  --bg-tertiary-color #f1f5f9
  --bg-hover-color #e2e8f0

  --code-bg-color: #f8fafc;
  --code-border-color: #e2e8f0;

  --border-normal-color #e2e8f0

  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)
}

/* 暗色主题色调 */
[data-theme="dark"] {
  --primary-normal-color #3b82f6
  --primary-light-color #1e3a5f

  --text-primary-color #f1f5f9
  --text-secondary-color #cbd5e1
  --text-muted-color #64748b
  --text-inverse-color #0f172a

  --bg-primary-color #0f172a
  --bg-secondary-color #1e293b
  --bg-tertiary-color #334155
  --bg-hover-color #475569

  --code-bg-color: #1e293b;
  --code-border-color: #334155;

  --border-normal-color #334155

  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -4px rgba(0, 0, 0, 0.3);
}
