main .category-layout {
  max-width 1280px
  margin 0 auto
  padding 0 var(--spacing-lg)

  display flex
  flex-direction row
  gap var(--spacing-2xl)
  flex-wrap nowrap
}

main .category-layout .category-brand {
  padding var(--spacing-md)
  background-color var(--bg-secondary-color)
  border 1px solid var(--border-normal-color)
  border-radius var(--radius-md)
  color var(--text-primary-color)

  display flex
  align-items center
  gap var(--spacing-sm)
}
