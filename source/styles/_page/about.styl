main .about-layout {
  max-width 768px
  margin 0 auto
  padding 0 var(--spacing-lg)

  display flex
  flex-direction column
  gap var(--spacing-md)
}

main .about-layout .title {
  font-size var(--text-3xl)
  color var(--text-primary-color)

  display flex
  justify-content center
  margin-bottom  var(--spacing-md)
}
