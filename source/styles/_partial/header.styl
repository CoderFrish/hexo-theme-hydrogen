header {
  width 100%
  position fixed
  z-index var(--z-sticky)
}

header h1 {
  color var(--text-primary-color)
  font-size var(--text-xl)
  letter-spacing .02rem
}

header .mobile-layout {
  ul {
    list-style none

    li {
      border-radius var(--radius-md)
      transition all 150ms ease

      a {
        text-decoration none
      }

      a.active {
        color: var(--primary-normal-color)
      }

      a.inactive {
        color: var(--text-secondary-color)
      }

      &:hover {
        background-color var(--bg-hover-color)
      }
    }
  }
}

header .layout {
  max-width  1280px
  height 65px

  display flex
  align-items center

  margin 0 auto
  padding 0 var(--spacing-lg)
}

header .layout .toolbar {
  ul {
    display flex
    flex-direction row
    gap var(--spacing-sm)
    list-style none

    li button {
      height 40px
      width 40px

      display flex
      align-items center
      justify-content center

      background none
      border none
      font-family inherit
      font-size var(--text-2xl)
      border-radius var(--radius-md)
      transition all 150ms ease
      color var(--text-secondary-color)

      &:hover {
        background-color var(--bg-hover-color)
        cursor pointer
        color var(--text-primary-color)
      }
    }
  }
}

header .layout .navigation {
  flex 1
  display flex
  justify-content center

  a {
    text-decoration none
    border-radius var(--radius-md)
    transition all 150ms ease
    font-weight 500
    font-size var(--text-sm)
  }

  a.inactive {
    color var(--text-secondary-color)

    &:hover {
      color var(--text-primary-color)
      background-color var(--bg-hover-color)
    }
  }

  a.active {
    color var(--primary-normal-color)
    background-color var(--primary-light-color)
  }

  ul {
    list-style none

    display flex
    flex-direction row
    gap var(--spacing-md)

    a {
      display inline-block
      padding var(--spacing-sm) var(--spacing-md)
    }
  }
}

header .mobile-layout {
  display flex
  flex-direction column

  padding var(--spacing-md)

  ul li a {
    display block
    padding var(--spacing-md)
  }
}

header .mobile-background.inactive {
  display none
}

header .mobile-background {
  margin-top -1px
}

header .background, .mobile-background  {
  border-bottom 1px solid var(--border-normal-color)
  backdrop-filter blur(10px)

  /* 这里是因为byd Stylus不给 in oklab, 我真没招了（） */
  background-color unquote('color-mix(in oklab, var(--bg-primary-color) 90%, transparent)')
}

@media (max-width: 678px) {
  header .background .layout .navigation ul {
    display none
  }
}

@media (min-width 678px) {
  header .mobile-background {
    display none
  }

  header .background .layout .toolbar #mobile_menu_btn {
    display none
  }
}
