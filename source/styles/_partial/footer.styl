footer {
  background-color var(--bg-secondary-color)
  border 1px solid var(--border-normal-color)
  padding var(--spacing-2xl) 0
}

footer .layout {
  max-width 1280px
  margin 0 auto
  padding 0 var(--spacing-lg)

  display flex
  justify-content center
  align-items center
  flex-direction row
  flex-wrap wrap
  gap var(--spacing-md)
}

footer .layout .copyright, .powered {
  font-size var(--text-sm)
}

footer .layout .powered a, .copyright a {
  @extend base-link
}

footer .layout .copyright, .powered span {
  color var(--text-muted-color)
}

footer .layout .social a {
  color var(--text-muted-color)
  background-color var(--bg-tertiary-color)
  border-radius var(--redius-full)
  transition all 150ms ease

  display flex
  justify-content center
  align-items center
  width 36px
  height 36px

  &:hover{
    color var(--primary-normal-color)
    background-color var(--primary-light-color)
  }
}
