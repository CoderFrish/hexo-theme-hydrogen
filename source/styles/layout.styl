/* 这里主要放的是样式的基础属性，比如width，z-index */
/* 下面的那些import里面写的是让样式能看的属性 */
@import "_partial/header.styl"
@import "_partial/footer.styl"
@import "_partial/content.styl"

header {
  width 100%
  position fixed
  z-index var(--z-index-sticky)

  .mobile-background.inactive {
    display none
  }

  .mobile-layout {
    display flex
    flex-direction column

    padding var(--spacing-md)

    ul li a {
      display block
      padding var(--spacing-md)
    }
  }

  .layout {
    max-width  1280px
    height 65px

    display flex
    align-items center

    margin 0 auto
    padding 0 var(--spacing-lg)

    .navigation {
      flex 1
      display flex
      justify-content center

      ul {
        list-style none

        display flex
        flex-direction row
        gap var(--spacing-md)

        a {
          display inline-block
          padding var(--spacing-sm) var(--spacing-md)
        }
      }
    }

    .toolbar {
      ul {
        display flex
        flex-direction row
        gap var(--spacing-sm)

        li button {
          height 40px
          width 40px

          display flex
          align-items center
          justify-content center
        }
      }
    }
  }
}

footer {
  padding var(--spacing-2xl) 0

  .layout {
    max-width 1280px
    margin 0 auto
    padding 0 var(--spacing-lg)

    display flex
    justify-content center
    align-items center
    flex-direction row
    flex-wrap wrap
    gap var(--spacing-md)

    .social a {
      display flex
      justify-content center
      align-items center
      width 36px
      height 36px
    }
  }
}

@media (min-width 678px) {
  header .mobile-background {
    display none
  }

  header .background .layout .toolbar #mobile_menu_btn {
    display none
  }
}

@media (max-width: 678px) {
  header .background .layout .navigation ul {
    display none
  }
}

@media (max-width: 1024px) {
  main .index-layout .sidebar {
    display none
  }
}
