main .sidebar .author {
  @extend base-widget
  text-align center
}

main .sidebar .author .avatar {
  width 80px
  height 80px
  margin 0 auto var(--spacing-lg)
}

main .sidebar .author .avatar img {
  border-radius var(--redius-full)

  width 100%
  height 100%
  object-fit cover
}

main .sidebar .author h3 {
  font-weight 600
  font-size var(--text-lg)
  color var(--text-primary-color)
  margin 0 auto var(--spacing-xs)
}

main .sidebar .author p {
  font-size var(--text-sm)
  color var(--text-muted-color)
  padding-bottom var(--spacing-sm)
  margin-bottom var(--spacing-xs)
  border-bottom 1px solid var(--border-normal-color)
}

main .sidebar .author .about a {
  background-color var(--primary-normal-color)
  color var(--text-inverse-color)
  border none
  text-decoration none
  border-radius var(--radius-md)

  display inline-block
  width calc(100% - 40px)
  padding var(--spacing-sm) 0

  &:hover {
    cursor pointer;
  }
}

main .sidebar .author ul {
  list-style none
  margin var(--spacing-md) 0

  display flex
  justify-content center
  align-items center
  gap var(--spacing-md)
}

main .sidebar .author li {
  display inline-flex
  justify-content center
  align-items center

  flex-direction column

  .title {
    font-size: var(--text-xs);
    color: var(--text-muted-color);
  }

  .data {
    display: block;
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--primary-normal-color);
  }
}
