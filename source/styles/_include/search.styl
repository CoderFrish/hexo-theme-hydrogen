.search {
  z-index var(--z-modal)
  position fixed;
  top 0
  bottom 0
  left 0
  right 0

  background-color rgba(0, 0, 0, .5)
  backdrop-filter blur(5px)
  padding-top 10vh
  overflow hidden
}

.search.inactive {
  display none
}

.search .layout {
  max-width 600px
  margin 0 auto
  padding-top var(--spacing-md)
}

.search .layout .search-box {
  width 100%
  background var(--bg-primary-color)
  box-shadow var(--shadow-xl)
  border-radius var(--radius-md)
}

.search .layout .search-header {
  padding var(--spacing-md)
  border-bottom 1px solid var(--border-normal-color)
}

.search .layout .search-header .search-input {
  display flex
  align-items center
  gap var(--spacing-sm)
  background-color var(--bg-secondary-color)
  border-radius var(--radius-md)
  padding var(--spacing-sm) var(--spacing-md)
  border 1px solid var(--border-normal-color)
  transition all 150ms ease

  &:focus-within {
    border 1px solid var(--primary-normal-color)
  }
}

.search .layout .search-header .search-input input {
  flex 1
  background none
  border none
  outline none
  color var(--text-muted-color)
  font-size var(--text-base)
}

.search .layout .search-header .search-input iconify-icon {
  font-size var(--text-2xl)
  color var(--text-muted-color)
}

.search .layout .search-header .search-input button {
  background none
  border none
  flex-shrink 1
  display flex
  justify-content center
  align-items center
  width 32px
  height 32px
  border-radius var(--radius-md)
  transition all 150ms ease

  &:hover {
    iconify-icon {
      color var(--text-primary-color)
    }

    background-color var(--bg-hover-color)
    cursor pointer
  }
}

.search .layout .search-content {
  flex 1
  overflow-y auto
  overflow-x hidden
  padding var(--spacing-md)
}

.search .layout .search-content .search-tip {
  padding var(--spacing-xl)
  color var(--text-muted-color)
  text-align center
}

.search .layout .search-content a {
  display block
  text-decoration none

  background-color var(--bg-secondary-color)
  border 1px solid var(--border-normal-color)
  padding var(--spacing-md)
  margin-bottom var(--spacing-sm)
  border-radius var(--radius-md)
  transition all 150ms ease

  &:hover {
    border 1px solid var(--primary-normal-color)
    background-color var(--primary-light-color)
  }
}

.search .layout .search-content a .title {
  font-weight 600
  color var(--text-primary-color)
  margin-bottom var(--spacing-xs)
}

.search .layout .search-content a .excerpt {
  font-size var(--text-sm)
  color var(--text-secondary-color)
  margin-bottom var(--spacing-xs)
}
