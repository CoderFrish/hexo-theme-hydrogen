.markdown {
  font-size: var(--text-base);
  line-height: 1.75;
  color: var(--text-primary-color);
  word-wrap: break-word;
}

.markdown h1,
.markdown h2,
.markdown h3,
.markdown h4,
.markdown h5,
.markdown h6 {
  margin-top: var(--spacing-xl);
  margin-bottom: var(--spacing-md);
  font-weight: 600;
  line-height: 1.25rem;
  color: var(--text-primary);
}

.markdown h1 { font-size: var(--text-3xl); }
.markdown h2 { font-size: var(--text-2xl); }
.markdown h3 { font-size: var(--text-xl); }
.markdown h4 { font-size: var(--text-lg); }
.markdown h5 { font-size: var(--text-base); }
.markdown h6 { font-size: var(--text-sm); color: var(--text-secondary-color); }

.markdown h1:first-child,
.markdown h2:first-child,
.markdown h3:first-child {
  margin-top: 0;
}

/* 锚点链接 */
.markdown h1:hover .headerlink,
.markdown h2:hover .headerlink,
.markdown h3:hover .headerlink,
.markdown h4:hover .headerlink {
  opacity: 1;
}

.markdown .headerlink {
  margin-left: var(--spacing-sm);
  color: var(--primary-color-color);
  text-decoration: none;
  opacity: 0;
  transition: opacity var(--transition-fast);
}

/* 段落 */
.markdown p {
  margin-top: 0;
  margin-bottom: var(--spacing-md);
}

/* 链接 */
.markdown a {
  color: var(--primary-normal-color);
  text-decoration: none;
  transition: color 150ms ease;
}

.markdown a:hover {
  color: var(--primary-hover-color);
  text-decoration: underline;
}

/* 强调 */
.markdown strong {
  font-weight: 600;
  color: var(--text-primary-color);
}

.markdown em {
  font-style: italic;
}

/* 列表 */
.markdown ul,
.markdown ol {
  margin-top: 0;
  margin-bottom: var(--spacing-md);
  padding-left: var(--spacing-xl);
}

.markdown li {
  margin-bottom: var(--spacing-xs);
}

.markdown li > ul,
.markdown li > ol {
  margin-top: var(--spacing-xs);
  margin-bottom: 0;
}

/* 任务列表 */
.markdown .task-list-item {
  list-style: none;
}

.markdown .task-list-item input {
  margin-right: var(--spacing-sm);
}

/* 引用 */
.markdown blockquote {
  margin: var(--spacing-md) 0;
  padding: var(--spacing-md) var(--spacing-lg);
  border-left: 4px solid var(--primary-normal-color);
  background-color: var(--bg-secondary-color);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  color: var(--text-secondary-color);
}

.markdown blockquote > :first-child {
  margin-top: 0;
}

.markdown blockquote > :last-child {
  margin-bottom: 0;
}

.markdown code {
  padding: 0.2em 0.4em;
  font-family: var(--font-mono);
  font-size: 0.9em;
  background-color: var(--code-bg-color);
  border: 1px solid var(--code-border-color);
  border-radius: var(--radius-sm);
  color: var(--text-primary-color);
}

/* 代码块 */
.markdown pre {
  margin: var(--spacing-md) 0;
  padding: var(--spacing-md);
  overflow-x: auto;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  line-height: 1.6;
  background-color: var(--code-bg-color);
  border: 1px solid var(--code-border-color);
  border-radius: var(--radius-md);

  scrollbar-width: thin;            /* auto | thin | none */
  scrollbar-color: var(--bg-secondary-color) var(--border-normal-color);    /* 滑块颜色 轨道颜色 */
}

.markdown pre code {
  padding: 0;
  font-size: inherit;
  background: transparent;
  border: none;
  border-radius: 0;
}

/* 代码高亮 - 行号 */
.markdown figure.highlight {
  margin: var(--spacing-md) 0;
  overflow: hidden;
  border-radius: var(--radius-md);
  border: 1px solid var(--code-border-color);
}

.markdown figure.highlight pre {
  margin: 0;
  border: none;
  border-radius: 0;
}

.markdown figure.highlight .gutter {
  padding: var(--spacing-md);
  padding-right: 0;
  background-color: var(--code-bg-color);
  border-right: 1px solid var(--code-border-color);
  text-align: right;
  color: var(--text-muted-color);
  user-select: none;
}

.markdown figure.highlight .code {
  padding: var(--spacing-md);
}

.markdown table {
  width: 100%;
  margin: var(--spacing-md) 0;
  border-collapse: collapse;
  border-spacing: 0;
  overflow: hidden;
  border-radius: var(--radius-md);
  border: 1px solid var(--border-normal-color);
}

.markdown th,
.markdown td {
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1px solid var(--border-normal-color);
  text-align: left;
}

.markdown th {
  font-weight: 600;
  background-color: var(--bg-secondary-color);
}

.markdown tr:nth-child(2n) {
  background-color: var(--bg-secondary-color);
}

/* 分隔线 */
.markdown hr {
  height: 1px;
  margin: var(--spacing-xl) 0;
  background-color: var(--border-normal-color);
  border: none;
}

/* 图片 */
.markdown img {
  max-width: 100%;
  height: auto;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.markdown figure {
  margin: var(--spacing-lg) 0;
  text-align: center;
}

.markdown figcaption {
  margin-top: var(--spacing-sm);
  font-size: var(--text-sm);
  color: var(--text-muted-color);
}

/* 脚注 */
.markdown .footnotes {
  margin-top: var(--spacing-xl);
  padding-top: var(--spacing-lg);
  border-top: 1px solid var(--border-noral-color);
  font-size: var(--text-sm);
  color: var(--text-secondary-color);
}

/* 提示块 */
.markdown .note,
.markdown .tip,
.markdown .warning,
.markdown .danger {
  margin: var(--spacing-md) 0;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-md);
  border-left: 4px solid;
}

.markdown .note {
  background-color: var(--primary-light-color);
  border-color: var(--primary-noral-color);
}

.markdown .tip {
  background-color: rgba(34, 197, 94, 0.1);
  border-color: var(--success-color);
}

.markdown .warning {
  background-color: rgba(245, 158, 11, 0.1);
  border-color: var(--warning);
}

.markdown .danger {
  background-color: rgba(239, 68, 68, 0.1);
  border-color: var(--error);
}

/* 键盘按键 */
.markdown kbd {
  display: inline-block;
  padding: 0.2em 0.5em;
  font-family: var(--font-mono);
  font-size: 0.85em;
  line-height: 1;
  background-color: var(--bg-secondary-color);
  border: 1px solid var(--border-noral-color);
  border-radius: var(--radius-sm);
  box-shadow: 0 1px 0 var(--border-color);
}

/* 详情/摘要 */
.markdown details {
  margin: var(--spacing-md) 0;
  padding: var(--spacing-md);
  background-color: var(--bg-secondary-color);
  border-radius: var(--radius-md);
  border: 1px solid var(--border-normal-color);
}

.markdown summary {
  cursor: pointer;
  font-weight: 500;
  color: var(--text-primary-color);
}

.markdown details[open] summary {
  margin-bottom: var(--spacing-md);
}
