.author
    .avatar
        img(src=url_for(theme.author.avatar))

    h3 #{theme.author.name}

    p #{theme.author.description}

    ul
        li
            span(class="data") #{site.posts.length}
            span(class="title") 文章
        li
            span(class="data") #{site.tags.length}
            span(class="title") 标签
        li
            span(class="data") #{site.categories.length}
            span(class="title") 分类

    .about
        a(href="/about") 关于我
