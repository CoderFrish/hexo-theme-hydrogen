title #{page.title ? page.title + ' | ' + config.title : config.title}
meta(charset="utf-8")
meta(name="description" content=config.description)
link(rel="stylesheet" href=url_for("styles/hydrogen.css") type="text/css")

meta(name="viewport" content="width=device-width, initial-scale=1.0")
meta(http-equiv="X-UA-Compatible" content="ie=edge")
link(rel="preconnect" href="https://cdn.jsdelivr.net/")
link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex/dist/katex.min.css")

script(src=url_for("scripts/script.js"))
script(src="https://cdn.jsdelivr.net/npm/iconify-icon@2.0.0/dist/iconify-icon.min.js")

- if (config.favicon) {
    link(rel="icon" href=url_for(config.favicon))
- }

script(src="https://giscus.app/client.js"
    data-repo=theme.commits.repo.name
    data-repo-id=theme.commits.repo.id
    data-category=theme.commits.category.name
    data-category-id=theme.commits.category.id
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="preferred_color_scheme"
    data-lang="zh-CN"
    crossorigin="anonymous"
    async
)
